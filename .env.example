# Server
PORT=3001
# 逗號分隔的允許來源（Next.js 前端）。正式服要加上前端網域，例如：
# CORS_ORIGINS=http://localhost:3000,https://your-app.zeabur.app,https://www.yourdomain.com
# 也支援萬用子網域：https://*.zeabur.app
CORS_ORIGINS=http://localhost:3000

# Supabase（secret key 僅限後端，切勿提交或外流）
SUPABASE_URL=https://your-project-ref.supabase.co
# 新版 API key（Dashboard → Settings → API Keys → Secret keys，sb_secret_ 開頭）
SUPABASE_SECRET_KEY=your-secret-key
# 或舊版 service_role JWT（二擇一，SUPABASE_SECRET_KEY 優先）
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI 快速建檔（Gemini API，https://aistudio.google.com/apikey）
GEMINI_API_KEY=your-gemini-api-key
# GEMINI_MODEL=gemini-2.5-flash
